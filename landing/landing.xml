        <badge>Java · Swing</badge>
      </appCard>
      <appCard featured="false">
        <icon>📦</icon>
        <cardTitle>Jarraipena — Bezeroak</cardTitle>
        <cardDesc>Konturik gabe eta instalaziorik gabe. Bezeroek esteka bakarrarekin beren paketea noiz iritsiko den jakin dezakete.</cardDesc>
